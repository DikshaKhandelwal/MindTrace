# MindTrace — Frontend Environment Variables
# Copy this file to .env and fill in your keys.
# Get your OpenAI key at https://platform.openai.com/api-keys

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Used by Clarity Engine and Mind Check (client-side GPT calls).
VITE_OPENAI_KEY=sk-...your-key-here...

# ── Backend URL ───────────────────────────────────────────────────────────────
# Leave empty for local dev — Vite proxy forwards /api/* to localhost:3001.
# In production (Vercel), set this to your Render backend URL:
#   VITE_API_URL=https://mindtrace-api.onrender.com
VITE_API_URL=

# ── Backend (Render) — set in simulator/backend/.env or Render dashboard ─────
#   OPENAI_API_KEY=sk-...your-key-here...
#   ALLOWED_ORIGIN=https://your-app.vercel.app
