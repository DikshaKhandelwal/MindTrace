# MindTrace — Frontend Environment Variables
# Copy this file to .env and fill in your key.
# Get your key at https://platform.openai.com/api-keys

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Must be prefixed with VITE_ so Vite exposes it to the browser.
# Used by: Clarity Engine, Mind Check (client-side GPT calls).
VITE_OPENAI_KEY=sk-...your-key-here...

# ── Backend (Node / Express) ──────────────────────────────────────────────────
# The backend uses OPENAI_API_KEY (no VITE_ prefix).
# Set this in simulator/backend/.env:
#   OPENAI_API_KEY=sk-...your-key-here...
# Used by: Reality Simulator, Mind Café, Social Connect, Sleep Guardian, Burnout Detector.
